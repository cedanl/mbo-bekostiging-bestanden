{
  "name": "python-uv-dev",
  "build": { "dockerfile": "Dockerfile" },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "anthropic.claude-code",
        "n4eth.ty-type-checker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.testing.pytestEnabled": true
      }
    }
  },
  "postCreateCommand": "uv sync && uv pip install ty",
  "forwardPorts": [8501],
  "remoteUser": "vscode"
}
